{
  "name": "agent-pulse",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yao-yh/Agent-Pulse.git"
  },
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "dev": "turbo dev",
    "start": "pnpm --filter @agent-pulse/server start",
    "agent-pulse": "pnpm --filter @cashew-dev/agent-pulse start",
    "docs:dev": "pnpm --filter @agent-pulse/docs dev",
    "docs:build": "pnpm --filter @agent-pulse/docs build",
    "pack:npm": "pnpm build && pnpm --filter @cashew-dev/agent-pulse pack",
    "publish:npm": "pnpm build && pnpm --filter @cashew-dev/agent-pulse publish --access public",
    "check:docs": "node scripts/check-doc-structure.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^4.7.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
